<?xml version="1.0" encoding="utf-8"?>
<com.dw.widget.InsetsLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:insets="bottom|right">
    <com.dw.widget.LinearLayoutEx
        android:orientation="vertical"
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ViewStub
            android:theme="?attr/actionBarTheme"
            android:id="@+id/search_bar"
            android:layout="@layout/search_bar_stub"
            android:inflatedId="@+id/search_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <com.dw.android.widget.CSFrameLayout
            android:id="@+id/fragment1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:sink="?attr/sinkSizePrimary"
            app:sinkGravity="top"/>
    </com.dw.widget.LinearLayoutEx>
</com.dw.widget.InsetsLayout>
