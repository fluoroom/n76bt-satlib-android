<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="#000"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:divider="#888"
            android:showDividers="middle"
            android:dividerPadding="0dp">
            <include
                android:id="@+id/cha"
                layout="@layout/dev_status_ch"/>
            <include
                android:id="@+id/chb"
                layout="@layout/dev_status_ch"/>
            <TextView
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                android:textSize="18sp"
                android:textColor="#fff"
                android:gravity="center"
                android:id="@+id/status"
                android:background="?attr/selectableItemBackground"
                android:padding="8dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="100dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <androidx.cardview.widget.CardView
        android:id="@+id/rx"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="#000"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:minHeight="@dimen/audio_level_height">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/icon_spk"
                android:layout_width="@dimen/audio_level_height"
                android:layout_height="@dimen/audio_level_height"
                android:contentDescription="@null"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_play_i_l3"
                app:tint="?attr/colorPrimary"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/level_spk"
                android:layout_width="0dp"
                android:layout_height="@dimen/audio_level_height"
                android:layout_marginStart="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/icon_spk"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/icon_rssi"
                android:layout_width="@dimen/audio_level_height"
                android:layout_height="@dimen/audio_level_height"
                android:layout_marginTop="4dp"
                android:contentDescription="@null"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/icon_spk"
                app:srcCompat="@drawable/ic_antenna"
                app:tint="?attr/colorPrimary"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/level_rssi"
                android:layout_width="0dp"
                android:layout_height="@dimen/audio_level_height"
                android:layout_marginStart="2dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/icon_rssi"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
