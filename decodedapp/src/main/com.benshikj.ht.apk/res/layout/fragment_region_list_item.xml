<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/content"
        android:background="?attr/selectableItemBackground"
        android:padding="6dp"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:minHeight="@dimen/recommended_touch_area_size"
        android:layout_weight="1">
        <TextView
            android:textAppearance="?attr/textAppearanceListItem"
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <TextView
            android:textAppearance="?attr/textAppearanceListItemSmall"
            android:id="@+id/summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <com.dw.widget.ActionButton
        android:id="@+id/upload"
        android:layout_width="@dimen/recommended_touch_area_size"
        android:layout_height="match_parent"
        android:contentDescription="@string/upload_to_device"
        app:srcCompat="@drawable/ic_file_upload_black_24dp"
        app:tint="?attr/list_button_tint"/>
    <com.dw.widget.ActionButton
        android:id="@+id/del_btn"
        android:layout_width="@dimen/recommended_touch_area_size"
        android:layout_height="match_parent"
        android:contentDescription="@string/delete"
        app:srcCompat="@drawable/ic_delete_24dp"
        app:tint="?attr/list_button_tint"/>
</LinearLayout>
