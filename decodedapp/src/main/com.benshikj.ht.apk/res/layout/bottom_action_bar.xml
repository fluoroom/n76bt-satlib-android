<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="bottom"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:elevation="4dp">
    <View
        android:id="@+id/bottom_bar_div"
        android:background="?attr/colorAccent"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:gravity="bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.dw.widget.ActionButton
            android:layout_gravity="bottom"
            android:id="@+id/type"
            android:layout_width="@dimen/recommended_touch_area_size"
            android:layout_height="@dimen/recommended_touch_area_size"
            android:contentDescription="@string/action_modes"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:srcCompat="@drawable/ic_keyboard_24dp"
            app:tint="?attr/list_button_tint"/>
        <LinearLayout
            android:id="@+id/morse_code_bar"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@+id/input"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/type">
            <androidx.appcompat.widget.FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textAppearance="?attr/textAppearanceListItem"
                    android:gravity="center"
                    android:layout_gravity="right"
                    android:id="@+id/morse_code_output"
                    android:background="@drawable/bg_send"
                    android:scrollbars="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:maxLines="5"/>
            </androidx.appcompat.widget.FrameLayout>
            <com.dw.widget.ActionButton
                android:id="@+id/morse_code_play"
                android:layout_width="@dimen/recommended_touch_area_size"
                android:layout_height="@dimen/recommended_touch_area_size"
                android:contentDescription="@string/preview"
                app:srcCompat="@drawable/ic_volume_up_24dp"
                app:tint="?attr/list_button_tint"/>
        </LinearLayout>
        <Button
            android:id="@+id/hold_to_speak"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="@string/hold_to_speak"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/place"
            app:layout_constraintStart_toEndOf="@+id/type"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/Widget.AppCompat.Button.Borderless.Colored"/>
        <androidx.appcompat.widget.FrameLayout
            android:id="@+id/transmission"
            android:background="@drawable/bg_tx_button"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:elevation="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="w,1:1"
            app:layout_constraintEnd_toStartOf="@+id/place"
            app:layout_constraintHeight_max="30mm"
            app:layout_constraintStart_toEndOf="@+id/type"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="30mm">
            <com.dw.widget.ActionButton
                android:id="@+id/tx"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:contentDescription="@string/hold_to_speak"
                app:srcCompat="@drawable/ic_voice_24dp"/>
        </androidx.appcompat.widget.FrameLayout>
        <EditText
            android:id="@+id/input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="3"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/send"
            app:layout_constraintStart_toEndOf="@+id/type"/>
        <com.dw.widget.ActionButton
            android:id="@+id/send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/send"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/place"
            app:srcCompat="@drawable/ic_send_24dp"
            app:tint="?attr/list_button_tint"/>
        <com.dw.widget.ActionButton
            android:id="@+id/place"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/sendLocation"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/ic_place_24dp"
            app:tint="?attr/list_button_tint"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.dw.ht.widget.DTMFKeyboard
        android:id="@+id/dtmf_keyboard"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dtmf_keyboard_h"/>
</LinearLayout>
