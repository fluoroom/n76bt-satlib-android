<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:gravity="center"
        android:id="@+id/number"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:gravity="center"
        android:id="@+id/message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/number"/>
    <info.hoang8f.android.segmented.SegmentedGroup
        android:orientation="horizontal"
        android:id="@+id/modulation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:layout_weight="1"
        android:layout_marginStart="11dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/message"
        app:sc_border_width="1dp"
        app:sc_tint_color="?attr/colorPrimary">
        <RadioButton
            android:id="@+id/fm"
            android:text="FM"
            style="@style/Widget.RadioButton"/>
        <RadioButton
            android:id="@+id/am"
            android:text="AM"
            style="@style/Widget.RadioButton"/>
        <RadioButton
            android:id="@+id/dmr"
            android:text="DMR"
            style="@style/Widget.RadioButton"/>
    </info.hoang8f.android.segmented.SegmentedGroup>
    <androidx.gridlayout.widget.GridLayout
        android:id="@+id/keyboard"
        android:layout_width="match_parent"
        android:layout_height="@dimen/number_keyboard_h"
        android:layout_marginTop="3dp"
        android:layout_marginBottom="8dp"
        android:maxHeight="220dp"
        android:minHeight="180dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:columnCount="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/modulation">
        <Button
            android:text="1"
            style="@style/number_button"/>
        <Button
            android:text="2"
            style="@style/number_button"/>
        <Button
            android:text="3"
            style="@style/number_button"/>
        <Button
            android:text="4"
            style="@style/number_button"/>
        <Button
            android:text="5"
            style="@style/number_button"/>
        <Button
            android:text="6"
            style="@style/number_button"/>
        <Button
            android:text="7"
            style="@style/number_button"/>
        <Button
            android:text="8"
            style="@style/number_button"/>
        <Button
            android:text="9"
            style="@style/number_button"/>
        <com.dw.widget.ActionButton
            android:id="@+id/backspace"
            android:scaleType="center"
            android:contentDescription="@string/backspace"
            app:srcCompat="@drawable/ic_backspace_24dp"
            app:tint="?android:attr/textColorPrimary"
            style="@style/number_button"/>
        <Button
            android:text="0"
            style="@style/number_button"/>
        <Button
            android:id="@+id/ok"
            android:text="@android:string/ok"
            style="@style/number_button"/>
    </androidx.gridlayout.widget.GridLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
