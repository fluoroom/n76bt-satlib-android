<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:theme="@style/AppTheme.AppBarOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/content"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.dw.widget.ActionButton
                android:id="@+id/back"
                android:layout_width="48dp"
                android:layout_height="?attr/actionBarSize"
                android:layout_marginLeft="0dp"
                android:layout_marginTop="0dp"
                android:contentDescription="@string/back"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_arrow_back_black_24dp"
                app:tint="?android:attr/textColorPrimary"/>
            <TextView
                android:textAppearance="@style/TextAppearance.AppCompat.Title"
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginRight="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/radio"
                app:layout_constraintBottom_toBottomOf="@+id/back"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintLeft_toRightOf="@+id/back"
                app:layout_constraintRight_toLeftOf="@+id/star"
                app:layout_constraintTop_toTopOf="@+id/back"/>
            <com.dw.widget.ActionButton
                android:id="@+id/star"
                android:layout_width="wrap_content"
                android:layout_height="?attr/actionBarSize"
                android:layout_marginTop="0dp"
                android:layout_marginRight="0dp"
                android:layout_marginBottom="8dp"
                android:minWidth="@dimen/recommended_touch_area_size"
                app:layout_constraintBottom_toBottomOf="@+id/back"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_star_black_24dp"
                app:tint="?android:attr/textColorPrimary"/>
            <TextView
                android:textAppearance="@style/TextAppearance.AppCompat.Title"
                android:textSize="32sp"
                android:gravity="center"
                android:id="@+id/freq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginRight="8dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textAppearance="@style/TextAppearance.AppCompat.Title"
                android:textSize="24sp"
                android:gravity="center"
                android:id="@+id/name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="0dp"
                android:layout_marginRight="8dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/freq"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/vol_status"
                android:padding="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="8dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/name"
                app:srcCompat="@drawable/ic_play_i_l3"
                app:tint="?android:attr/textColorPrimary"/>
            <SeekBar
                android:theme="@style/AppTheme.SeekBar"
                android:id="@+id/vol"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50"
                app:layout_constraintBottom_toBottomOf="@+id/vol_status"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintLeft_toRightOf="@+id/vol_status"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="@+id/vol_status"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/recommended_touch_area_size">
            <com.dw.widget.ActionButton
                android:id="@+id/seek_down"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:contentDescription="@string/searchForward"
                app:srcCompat="@drawable/ic_skip_previous_24dp"
                app:tint="?android:attr/textColorPrimary"/>
            <com.dw.widget.ActionButton
                android:id="@+id/previous"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:contentDescription="@string/fineTuneForward"
                app:srcCompat="@drawable/ic_fast_rewind_24dp"
                app:tint="?android:attr/textColorPrimary"/>
            <com.dw.widget.ActionButton
                android:id="@+id/play_stop"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:srcCompat="@drawable/ic_play_arrow_24dp"
                app:tint="?android:attr/textColorPrimary"/>
            <com.dw.widget.ActionButton
                android:id="@+id/next"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:contentDescription="@string/fineTuneBackward"
                app:srcCompat="@drawable/ic_fast_forward_24dp"
                app:tint="?android:attr/textColorPrimary"/>
            <com.dw.widget.ActionButton
                android:id="@+id/seek_up"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:contentDescription="@string/searchBackward"
                app:srcCompat="@drawable/ic_skip_next_24dp"
                app:tint="@color/colorRadioButton"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>
    <com.dw.android.widget.GridRecyclerView
        android:id="@+id/list"
        android:padding="3dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:column_width="120dp"/>
</LinearLayout>
